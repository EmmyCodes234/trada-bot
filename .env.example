# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenModel.ai API key
OPENMODEL_API_KEY=your_openmodel_api_key_here
OPENMODEL_BASE_URL=https://api.openmodel.ai

# Model selection (via OpenModel)
ANALYSIS_MODEL=deepseek-v4-flash

# Crypto Exchange Testnet (Binance)
BINANCE_TESTNET_API_KEY=your_binance_testnet_key
BINANCE_TESTNET_SECRET=your_binance_testnet_secret

# Stock Paper Trading (Alpaca)
ALPACA_API_KEY=your_alpaca_paper_key
ALPACA_SECRET_KEY=your_alpaca_paper_secret
ALPACA_PAPER=true

# Portfolio config
MAX_POSITION_SIZE_PCT=10
MAX_DAILY_TRADES=5
STOP_LOSS_PCT=5
